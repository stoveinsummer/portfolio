# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/.vinext/
/out/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Environment and local configuration. Only sanitized templates are allowed.
.env
.env.*
!.env.example
!.env.*.example
*.local

# Credentials, certificates, and signing material
*.key
*.p12
*.pfx
*.jks
*.keystore
credentials*.json
service-account*.json
secrets*.json
.npmrc
.pnpmrc

# Private data and exports
/private/
/local/
/captures/
/screenshots/
/data/private/
/public/private/
*.sqlite
*.sqlite3
*.db
*.bak
*.backup

# Local AI/editor workspace state
/.codex/
/.agents/
/.idea/
/.vscode/

# vercel
.vercel

# typescript
next-env.d.ts
/dist/
/.wrangler/
/outputs/
/work/

# Local photo originals; optimized WebP copies in public/photos/web are published.
/public/photos/*.jpg
/public/photos/*.jpeg
/public/photos/*.png
/public/photos/*.heic
/public/photos/*.dng
/public/photos/*.raw
